FROM node:18-alpine

WORKDIR /app

# Install dependencies
COPY package*.json ./
RUN yarn install --frozen-lockfile

# Copy source code
COPY . .

# Set build-time API URL
ARG NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL

# Build the app
RUN yarn build
EXPOSE 3000

# Use development mode with hot reload
CMD ["yarn", "dev"]
